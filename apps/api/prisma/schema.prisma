model TenderRequest {
  id               String @id @default(cuid())
  pending_scope_id String @unique
  customer_id      String

  // How providers were selected
  selection_mode SelectionMode @default(AUTO_MATCH)

  // Immutable scope snapshot captured at publish time
  title          String
  domain         String
  scope_snapshot Json

  // Eligibility criteria — populated only when selection_mode = AUTO_MATCH
  // { provider_types, requires_kyc, requires_insurance,
  //   min_experience_years, required_certs[] }
  eligibility_criteria Json?

  // Tender settings
  max_proposals       Int      @default(5)
  deadline_days       Int      @default(7)
  submission_deadline DateTime

  // State
  status              TenderStatus @default(OPEN)
  invited_count       Int          @default(0)
  proposal_count      Int          @default(0)
  awarded_proposal_id String?      @unique

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  closed_at  DateTime?

  customer         User               @relation("CustomerTenders", fields: [customer_id], references: [id])
  pending_scope    PendingScope       @relation(fields: [pending_scope_id], references: [id])
  invitations      TenderInvitation[]
  proposals        TenderProposal[]
  awarded_proposal TenderProposal?    @relation("AwardedProposal", fields: [awarded_proposal_id], references: [id])
  contract         TenderContract?    @relation("TenderContractRequest")

  @@index([customer_id, status])
  @@index([status])
  @@index([submission_deadline])
}

model TenderInvitation {
  id                 String  @id @default(cuid())
  tender_request_id  String
  invitee_user_id    String? // individual contractor's user id
  invitee_company_id String? // consulting company id

  status         TenderInvitationStatus @default(PENDING)
  notified_at    DateTime?
  viewed_at      DateTime?
  declined_at    DateTime?
  decline_reason String?

  created_at DateTime @default(now())

  tender          TenderRequest      @relation(fields: [tender_request_id], references: [id], onDelete: Cascade)
  invitee_user    User?              @relation("TenderInvitationsReceived", fields: [invitee_user_id], references: [id])
  invitee_company ConsultingCompany? @relation("CompanyTenderInvitations", fields: [invitee_company_id], references: [id])
  proposal        TenderProposal?

  @@unique([tender_request_id, invitee_user_id])
  @@unique([tender_request_id, invitee_company_id])
  @@index([tender_request_id, status])
  @@index([invitee_user_id])
  @@index([invitee_company_id])
}

// ─── IT Domain catalogue ─────────────────────────────────────────────────────
// Source of truth for all domain labels, icons, and insurance tier classification.
// All UI lists must be driven from this table via GET /api/v1/domains.

model ITDomain {
  id             String   @id @default(cuid())
  key            String   @unique // matches Domain enum values
  label          String // e.g. "Cloud Infrastructure"
  short_label    String? // e.g. "Cloud"
  icon           String? // emoji or icon token
  description    String?
  sort_order     Int      @default(0)
  is_active      Boolean  @default(true)
  insurance_tier String   @default("STANDARD") // STANDARD | ELEVATED | HIGH_RISK
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([is_active])
  @@index([sort_order])
}

model TenderProposal {
  id                    String  @id @default(cuid())
  tender_request_id     String
  invitation_id         String  @unique
  submitted_by_user_id  String
  contractor_profile_id String?
  company_id            String?

  // Proposal content
  cover_letter          String   @db.Text
  solution_details      String?  @db.Text
  approach_notes        String?  @db.Text
  proposed_price_aud    Decimal  @db.Decimal(10, 2)
  proposed_hours        Int?
  timeline_days         Int
  certifications        String[] @default([])
  deliverables          Json?
  proposed_milestones   Json?
  attachment_blob_paths String[] @default([])
  terms_and_conditions  String?  @db.Text

  // State
  status           TenderProposalStatus @default(DRAFT)
  submitted_at     DateTime?
  withdrawn_at     DateTime?
  awarded_at       DateTime?
  rejected_at      DateTime?
  rejection_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tender             TenderRequest      @relation(fields: [tender_request_id], references: [id], onDelete: Cascade)
  invitation         TenderInvitation   @relation(fields: [invitation_id], references: [id])
  submitted_by       User               @relation("TenderProposalsSubmitted", fields: [submitted_by_user_id], references: [id])
  contractor_profile ContractorProfile? @relation("ContractorTenderProposals", fields: [contractor_profile_id], references: [id])
  company            ConsultingCompany? @relation("CompanyTenderProposals", fields: [company_id], references: [id])
  awarded_tender     TenderRequest?     @relation("AwardedProposal")
  contract           TenderContract?    @relation("TenderContractProposal")

  @@index([tender_request_id, status])
  @@index([contractor_profile_id])
  @@index([company_id])
  @@index([submitted_by_user_id])
}

// ─── Tender Contract ──────────────────────────────────────────────────────────
// Created when a customer awards a tender. Replaces the Order table for
// AI-scoped tender work. Has its own milestone-driven payment lifecycle.

model TenderContract {
  id String @id @default(cuid())

  // References
  tender_request_id  String  @unique
  proposal_id        String  @unique
  customer_id        String
  company_id         String?
  contractor_user_id String?

  // Agreed terms (snapshot from proposal at contract creation)
  agreed_price_aud      Decimal @db.Decimal(10, 2)
  agreed_timeline_days  Int
  agreed_hours          Int?
  scope_snapshot        Json
  deliverables_snapshot Json?

  // State
  status              TenderContractStatus @default(PENDING)
  customer_notes      String?              @db.Text
  cancellation_reason String?

  // Activity log (append-only JSON array)
  activity_log Json @default("[]")

  // Dates
  created_at   DateTime  @default(now())
  accepted_at  DateTime?
  completed_at DateTime?
  cancelled_at DateTime?
  updated_at   DateTime  @updatedAt

  // Relations
  tender       TenderRequest           @relation("TenderContractRequest", fields: [tender_request_id], references: [id])
  proposal     TenderProposal          @relation("TenderContractProposal", fields: [proposal_id], references: [id])
  customer     User                    @relation("CustomerContracts", fields: [customer_id], references: [id])
  company      ConsultingCompany?      @relation("CompanyContracts", fields: [company_id], references: [id])
  contractor   User?                   @relation("ContractorContracts", fields: [contractor_user_id], references: [id])
  milestones   TenderMilestone[]
  deliverables TenderDeliverable[]
  invoices     TenderContractInvoice[]

  @@index([customer_id, status])
  @@index([company_id, status])
  @@index([contractor_user_id])
  @@index([status])
}

model TenderMilestone {
  id          String @id @default(cuid())
  contract_id String
  sort_order  Int    @default(0)

  name        String
  description String?   @db.Text
  amount_aud  Decimal   @db.Decimal(10, 2)
  due_date    DateTime?

  status TenderMilestoneStatus @default(PENDING)

  // Company submits evidence
  submitted_at        DateTime?
  completion_notes    String?   @db.Text
  evidence_blob_paths String[]  @default([])

  // Customer approves
  approved_at    DateTime?
  approved_by_id String?

  // Payment
  invoiced_at DateTime?
  paid_at     DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contract TenderContract         @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  invoice  TenderContractInvoice?

  @@index([contract_id, status])
  @@index([contract_id, sort_order])
}

model TenderDeliverable {
  id          String @id @default(cuid())
  contract_id String
  sort_order  Int    @default(0)

  title           String
  description     String?   @db.Text
  completed       Boolean   @default(false)
  completed_at    DateTime?
  completed_by_id String?

  created_at DateTime @default(now())

  contract TenderContract @relation(fields: [contract_id], references: [id], onDelete: Cascade)

  @@index([contract_id])
}

// ─── TenderContract Invoice / Payment / Payout models ────────────────────────

model TenderContractInvoice {
  id                 String  @id @default(cuid())
  contract_id        String
  milestone_id       String? @unique
  company_id         String?
  contractor_user_id String?
  created_by_id      String

  invoice_number String  @unique // INV-TC-2026-000001
  amount_aud     Decimal @db.Decimal(10, 2) // ex-GST
  gst_amount_aud Decimal @default(0) @db.Decimal(10, 2)
  total_aud      Decimal @db.Decimal(10, 2) // inc-GST

  status        String    @default("SENT") // SENT | PAID | VOID
  due_date      DateTime?
  pdf_blob_path String?
  sent_at       DateTime  @default(now())
  paid_at       DateTime?

  stripe_payment_intent_id String?

  // Tax classification
  is_tax_invoice          Boolean @default(true)
  gst_free                Boolean @default(false)
  is_cross_border         Boolean @default(false)
  provider_gst_registered Boolean @default(false)
  provider_abn            String?
  customer_legal_name     String?
  customer_abn            String?
  // ATO-compliant invoice copy (added 2026-05-07). Computed at invoice
  // creation based on supplier's GST registration, country, and whether
  // the supply is cross-border. Rendered verbatim under the GST line on
  // the PDF when GST isn't being charged at 10%.
  // Examples:
  //   "GST 10% applied"
  //   "Supplier not registered for GST"
  //   "GST-free export of services (s38-190 GST Act)"
  //   "Reverse-charge applies — recipient liable for GST"
  gst_treatment_reason    String?

  // Optional metadata supplied by the supplier when raising the invoice.
  // customer_po_number is the customer's internal PO that AP teams require
  // to match the invoice. service_period_* records when the work was
  // performed (separate from issue/due dates) — required for accrual
  // accounting and standard on most B2B invoices.
  customer_po_number   String?
  service_period_start DateTime?
  service_period_end   DateTime?

  // Payment-completion email tracking — set when we send the customer-copy
  // and supplier-receipt emails on PAID, so a retry doesn't double-send.
  paid_emails_sent_at DateTime?

  // ── Direct-payment fields (Phase 2: subscription-only marketplace) ─────
  // Mirrors Order direct-payment fields. The `status` string adopts new
  // values for direct-payment invoices: AWAITING_PAYMENT → PAYMENT_REPORTED
  // → PAID. Legacy invoices keep using SENT → PAID via Stripe.
  payment_method              PaymentMethod?
  payment_reference           String?
  payment_amount_reported_aud Decimal?       @db.Decimal(10, 2)
  customer_reported_paid_at   DateTime?
  supplier_confirmed_paid_at  DateTime?
  payment_evidence_blob_path  String?
  payment_evidence_file_name  String?
  payment_dispute_reason      String?
  payment_dispute_raised_at   DateTime?
  // Append-only history mirroring the Order.payment_evidence_history field.
  payment_evidence_history    Json           @default("[]")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contract      TenderContract              @relation(fields: [contract_id], references: [id])
  milestone     TenderMilestone?            @relation(fields: [milestone_id], references: [id])
  company       ConsultingCompany?          @relation("TCInvoiceCompany", fields: [company_id], references: [id])
  created_by    User                        @relation("TCInvoiceCreatedBy", fields: [created_by_id], references: [id])
  bank_transfer TenderContractBankTransfer?
  payout_record TenderContractPayoutRecord?

  @@index([contract_id])
  @@index([status])
}

model TenderContractBankTransfer {
  id          String @id @default(cuid())
  invoice_id  String @unique
  contract_id String

  method            String // PAYID_EMAIL | AU_BSB | SWIFT
  status            String  @default("PENDING") // PENDING | CONFIRMED | REJECTED
  amount_aud        Decimal @db.Decimal(10, 2)
  payment_reference String?
  receipt_blob_path String?

  submitted_at     DateTime  @default(now())
  confirmed_at     DateTime?
  confirmed_by_id  String?
  rejected_at      DateTime?
  rejection_reason String?
  admin_notes      String?

  invoice      TenderContractInvoice @relation(fields: [invoice_id], references: [id])
  confirmed_by User?                 @relation("TCBankTransferConfirmedBy", fields: [confirmed_by_id], references: [id])

  @@index([contract_id])
  @@index([status])
}

model TenderContractPayoutRecord {
  id                 String  @id @default(cuid())
  invoice_id         String  @unique
  contract_id        String
  milestone_id       String?
  company_id         String?
  contractor_user_id String?
  processed_by_id    String?

  method String // STRIPE_CONNECT | AU_BANK | OVERSEAS_BANK
  status String @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED

  gross_amount_aud Decimal @db.Decimal(10, 2)
  platform_fee_aud Decimal @db.Decimal(10, 2)
  net_amount_aud   Decimal @db.Decimal(10, 2)

  transfer_reference String?
  receipt_blob_path  String?
  admin_notes        String?

  commission_invoice_blob_path String?
  commission_invoice_number    String?

  initiated_at   DateTime?
  completed_at   DateTime?
  failed_at      DateTime?
  failure_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoice      TenderContractInvoice @relation(fields: [invoice_id], references: [id])
  processed_by User?                 @relation("TCPayoutProcessedBy", fields: [processed_by_id], references: [id])

  @@index([contract_id])
  @@index([status])
}

enum TenderContractStatus {
  PENDING
  ACTIVE
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

enum TenderMilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  INVOICED
  PAID
  DISPUTED
}

// ─── Admin Document Request ───────────────────────────────────────────────────
// Admin can request additional documents from a company or contractor before
