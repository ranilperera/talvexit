generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                             String                       @id @default(cuid())
  email                          String                       @unique
  password_hash                  String
  account_type                   AccountType
  full_name                      String
  email_verified                 Boolean                      @default(false)
  email_verified_at              DateTime?
  mfa_enabled                    Boolean                      @default(false)
  mfa_secret                     String?
  account_locked                 Boolean                      @default(false)
  locked_until                   DateTime?
  failed_login_count             Int                          @default(0)
  last_login_at                  DateTime?
  created_at                     DateTime                     @default(now())
  updated_at                     DateTime                     @updatedAt
  deleted_at                     DateTime?
  email_verification_expires     DateTime?
  email_verification_token       String?
  password_reset_expires         DateTime?
  password_reset_token           String?
  mfa_backup_codes               Json                         @default("[]")
  must_change_password           Boolean                      @default(false)
  theme_preference               String                       @default("system")
  notification_preferences       Json                         @default("{}")
  notifications                  Notification[]
  abn                            String?
  abn_verified                   Boolean                      @default(false)
  abn_verified_at                DateTime?
  acn                            String?
  business_type                  String?
  customer_terms_signed          Boolean                      @default(false)
  customer_terms_signed_at       DateTime?
  customer_terms_version         String?
  foreign_bank_country           String?
  gst_registered                 Boolean                      @default(false)
  gst_registered_verified        Boolean                      @default(false)
  is_foreign_entity              Boolean                      @default(false)
  legal_name                     String?
  professional_indemnity_insured Boolean                      @default(false)
  provider_agreement_signed      Boolean                      @default(false)
  provider_agreement_signed_at   DateTime?
  provider_agreement_version     String?
  public_liability_insured       Boolean                      @default(false)
  sanctions_screened             Boolean                      @default(false)
  sanctions_screened_at          DateTime?
  super_liability_flag           Boolean                      @default(false)
  tax_form_provided              Boolean                      @default(false)
  tax_form_provided_at           DateTime?
  tax_form_type                  String?
  tax_residency_country          String?                      @default("AU")
  withholding_required           Boolean                      @default(false)
  abn_verified_name              String?
  anzsic_code                    String?
  billing_address_1              String?
  billing_address_2              String?
  billing_city                   String?
  billing_country                String?                      @default("AU")
  billing_email                  String?
  billing_phone                  String?
  billing_postcode               String?
  billing_state                  String?
  business_registrations         Json?                        @default("[]")
  compliance_documents           Json?                        @default("[]")
  entity_type                    String?
  legal_entity_name              String?
  trading_name                   String?
  vat_number                     String?
  website                        String?
  aml_checks_reviewed            AmlCheck[]                   @relation("AmlReviewer")
  aml_checks_triggered           AmlCheck[]                   @relation("AmlTrigger")
  aml_checks_received            AmlCheck[]                   @relation("AmlSubject")
  audit_logs                     AuditLog[]
  contact_enquiries_responded    ContactEnquiry[]             @relation("ContactEnquiryResponder")
  contact_enquiry_responses_sent ContactEnquiryResponse[]     @relation("ContactEnquiryResponseAuthor")
  change_requests_decided        ChangeRequest[]              @relation("ChangeRequestDecider")
  change_requests_raised         ChangeRequest[]              @relation("ChangeRequestRaiser")
  sent_company_invitations       CompanyInvitation[]          @relation("InvitationSender")
  invoices_created               CompanyInvoice[]             @relation("InvoiceCreator")
  bank_transfer_confirmations    BankTransferPayment[]        @relation("BankTransferConfirmer")
  member_inviter_records         CompanyMember[]              @relation("MemberInviter")
  company_memberships            CompanyMember[]              @relation("CompanyMemberships")
  proposals_created              CompanyOrderProposal[]       @relation("ProposalCreator")
  payouts_processed              CompanyPayoutRecord[]        @relation("PayoutProcessor")
  primary_admin_of               ConsultingCompany?           @relation("CompanyPrimaryAdmin")
  contractor_profile             ContractorProfile?
  customer_profile               CustomerProfile?
  administered_disputes          Dispute[]                    @relation("DisputeAdmin")
  determined_disputes            Dispute[]                    @relation("DisputeDeterminer")
  disputes_raised                Dispute[]                    @relation("DisputeRaiser")
  dispute_submissions            DisputeSubmission[]
  email_otp_challenges           EmailOtpChallenge[]
  legal_acceptances              LegalDocAcceptance[]
  orders_as_contractor           Order[]                      @relation("OrderContractor")
  orders_as_customer             Order[]                      @relation("OrderCustomer")
  order_executions               Order[]                      @relation("OrderExecutingMember")
  credentials_stored             OrderAccessCredential[]      @relation("CredentialStorer")
  order_chat_messages            OrderChatMessage[]           @relation("OrderChatSender")
  deliverables_uploaded          OrderDeliverable[]
  sent_messages                  OrderMessage[]               @relation("SentMessages")
  org_memberships                OrgMember[]
  created_organisations          Organisation[]               @relation("OrgCreator")
  pending_scopes                 PendingScope[]
  tax_declarations               ProviderTaxDeclaration[]     @relation("UserTaxDeclarations")
  ratings_submitted              Rating[]                     @relation("RatingSubmitter")
  refresh_tokens                 RefreshToken[]
  smr_requests                   ScopeModificationRequest[]   @relation("SmrRequester")
  smr_responses                  ScopeModificationRequest[]   @relation("SmrResponder")
  supplier_statements            SupplierStatement[]          @relation("UserSupplierStatements")
  company_task_assignments       Task[]                       @relation("TaskAssignedMember")
  tasks                          Task[]
  sent_task_messages             TaskMessage[]                @relation("SentTaskMessages")
  customer_threads               TaskThread[]                 @relation("CustomerThreads")
  sessions_as_host               VideoSession[]               @relation("SessionHost")
  sessions_as_participant        VideoSession[]               @relation("SessionParticipant")
  work_logs                      WorkLog[]
  tender_requests                TenderRequest[]              @relation("CustomerTenders")
  tender_invitations_received    TenderInvitation[]           @relation("TenderInvitationsReceived")
  tender_proposals_submitted     TenderProposal[]             @relation("TenderProposalsSubmitted")
  customer_contracts             TenderContract[]             @relation("CustomerContracts")
  contractor_contracts           TenderContract[]             @relation("ContractorContracts")
  tc_invoices_created            TenderContractInvoice[]      @relation("TCInvoiceCreatedBy")
  tc_bank_transfers_confirmed    TenderContractBankTransfer[] @relation("TCBankTransferConfirmedBy")
  tc_payouts_processed           TenderContractPayoutRecord[] @relation("TCPayoutProcessedBy")
  admin_document_requests        AdminDocumentRequest[]       @relation("DocRequestedBy")
  reviewed_legal_name_requests   LegalNameChangeRequest[]     @relation("LegalNameReviewer")

  // ── Subscription module ──────────────────────────────────────────────────────
  stripe_customer_id         String?           @unique
  subscription               Subscription?
  subscription_invoices      Invoice[]         @relation("InvoiceBilledToUser")
  service_invoices_sent      ServiceInvoice[]  @relation("ServiceInvoiceFrom")
  service_invoices_received  ServiceInvoice[]  @relation("ServiceInvoiceTo")
  payment_evidence_submitted PaymentEvidence[] @relation("PaymentEvidenceSubmitter")
  payment_evidence_reviewed  PaymentEvidence[] @relation("PaymentEvidenceReviewer")

  // ── B2B service-invoice payment instructions (Phase 5) ──────────────────
  // JSON shape: { stripe?: {...}, bank_au?: {...}, bank_swift?: {...},
  //               paypal?: {...}, wise?: {...}, other?: {...} }
  payment_methods Json @default("{}")

  // ── Admin sanctions (Phase 3: subscription-only marketplace) ─────────────
  // Suspend = reversible; Ban = permanent (still reversible by admin, but UX
  // treats it as terminal). Either applies independently of dispute outcomes —
  // admins decide based on dispute determinations or other evidence. Both
  // states block sign-in via authenticate middleware + login service.
  suspended_at          DateTime?
  suspended_reason      String?
  suspended_by_admin_id String?
  suspended_by          User?     @relation("UserSuspendedBy", fields: [suspended_by_admin_id], references: [id], onDelete: SetNull)
  suspended_users       User[]    @relation("UserSuspendedBy")
  banned_at             DateTime?
  banned_reason         String?
  banned_by_admin_id    String?
  banned_by             User?     @relation("UserBannedBy", fields: [banned_by_admin_id], references: [id], onDelete: SetNull)
  banned_users          User[]    @relation("UserBannedBy")

  @@index([email])
  @@index([account_type])
  @@index([email_verification_token])
  @@index([password_reset_token])
  @@index([suspended_at])
  @@index([banned_at])
}

model EmailOtpChallenge {
  id                   String    @id @default(cuid())
  user_id              String
  challenge_token_hash String    @unique
  otp_hash             String
  status               String    @default("PENDING")
  attempts             Int       @default(0)
  max_attempts         Int       @default(5)
  expires_at           DateTime
  ip_address           String?
  user_agent           String?
  created_at           DateTime  @default(now())
  verified_at          DateTime?
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@index([expires_at])
}

model ContractorProfile {
  id                          String                   @id @default(cuid())
  user_id                     String                   @unique
  status                      ContractorStatus         @default(INCOMPLETE)
  domains                     Domain[]
  skills                      String[]
  bio                         String?
  linkedin_url                String?
  hourly_rate_aud             Decimal?                 @db.Decimal(10, 2)
  timezone                    String?
  stripe_account_id           String?
  stripe_account_enabled      Boolean                  @default(false)
  completed_orders_count      Int                      @default(0)
  identity_status             IdentityStatus           @default(NOT_STARTED)
  kyc_status                  KycStatus                @default(NOT_STARTED)
  employment_type             EmploymentType?
  has_employer_consent        Boolean?
  employment_declared_at      DateTime?
  onboarding_step             Int                      @default(1)
  activated_at                DateTime?
  suspended_at                DateTime?
  suspension_reason           String?
  banned_at                   DateTime?
  ban_reason                  String?
  created_at                  DateTime                 @default(now())
  updated_at                  DateTime                 @updatedAt
  agreement_accepted_at       DateTime?
  agreement_version           String?
  availability_hours_per_week Int?
  available_from              DateTime?
  employer_name               String?
  identity_document_blob_path String?
  identity_document_type      String?
  phone                       String?
  insurance_tier_met          Boolean                  @default(false)
  overall_rating              Decimal?                 @db.Decimal(3, 1)
  rating_count                Int                      @default(0)
  legal_name                  String?
  legal_name_verified         Boolean                  @default(false)
  legal_name_requests         LegalNameChangeRequest[]
  invoices                    CompanyInvoice[]         @relation("ContractorInvoices")
  proposals                   CompanyOrderProposal[]   @relation("ContractorProposals")
  company_payout_records      CompanyPayoutRecord[]    @relation("ContractorPayoutRecords")
  tender_proposals            TenderProposal[]         @relation("ContractorTenderProposals")
  agreements                  ContractorAgreement[]
  payout_methods              ContractorPayoutMethod[]
  user                        User                     @relation(fields: [user_id], references: [id])
  arbitrator_disputes         Dispute[]                @relation("DisputeArbitrator")
  insurance_certificates      InsuranceCertificate[]
  orders                      Order[]
  payout_records              PayoutRecord[]
  ratings                     Rating[]
  stripe_connect_account      StripeConnectAccount?
  tasks                       Task[]
  video_sessions              VideoSession[]

  @@index([status])
  @@index([domains])
}

model ContractorPayoutMethod {
  id                     String            @id @default(cuid())
  contractor_profile_id  String
  method_type            String
  nickname               String?
  bank_name              String?
  account_holder_name    String?
  bsb                    String?
  account_number         String?
  account_number_last4   String?
  paypal_email           String?
  payid_email            String?
  payid_name             String?
  stripe_account_id      String?
  stripe_account_status  String?
  stripe_payouts_enabled Boolean           @default(false)
  swift_bic              String?
  iban                   String?
  iban_last4             String?
  bank_address           String?
  bank_country           String?
  correspondent_bank     String?
  wise_account_id        String?
  wise_email             String?
  payoneer_email         String?
  other_platform_name    String?
  other_account_id       String?
  other_instructions     String?
  currency               String            @default("AUD")
  aml_documents          Json              @default("[]")
  is_primary             Boolean           @default(false)
  verification_status    String            @default("PENDING")
  verified_at            DateTime?
  verified_by_id         String?
  rejection_reason       String?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  contractor_profile     ContractorProfile @relation(fields: [contractor_profile_id], references: [id], onDelete: Cascade)

  @@index([contractor_profile_id])
  @@index([method_type])
}

model InsuranceCertificate {
  id                    String             @id @default(cuid())
  contractor_id         String?
  insurer_name          String
  policy_number         String
  insurance_type        InsuranceType
  coverage_amount_aud   Decimal            @db.Decimal(12, 2)
  policy_start_date     DateTime
  policy_expiry_date    DateTime
  worldwide_coverage    Boolean            @default(false)
  tier                  InsuranceTier
  certificate_blob_path String
  status                InsuranceStatus    @default(PENDING_REVIEW)
  reviewed_by           String?
  reviewed_at           DateTime?
  rejection_reason      String?
  admin_notes           String?
  verified_at           DateTime?
  expired_at            DateTime?
  superseded_at         DateTime?
  expiry_reminder_sent  Int                @default(0)
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  company_id            String?
  company               ConsultingCompany? @relation("CompanyInsurance", fields: [company_id], references: [id])
  contractor            ContractorProfile? @relation(fields: [contractor_id], references: [id])

  @@index([contractor_id])
  @@index([company_id])
  @@index([status])
  @@index([policy_expiry_date])
}

model ContractorAgreement {
  id            String            @id @default(cuid())
  contractor_id String
  document_type String
  version       String
  accepted_at   DateTime          @default(now())
  ip_address    String?
  user_agent    String?
  blob_path     String?
  contractor    ContractorProfile @relation(fields: [contractor_id], references: [id])

  @@index([contractor_id])
}

model CustomerProfile {
  id           String   @id @default(cuid())
  user_id      String   @unique
  company_name String?
  country      String   @default("AU")
  phone        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user         User     @relation(fields: [user_id], references: [id])
}

model RefreshToken {
  id         String    @id @default(cuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  revoked_at DateTime?
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
}

model LegalDocAcceptance {
  id            String   @id @default(cuid())
  user_id       String
  document_type String
  version       String
  accepted_at   DateTime @default(now())
  ip_address    String
  user_agent    String?
  user          User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, document_type, version])
}

/// APPEND ONLY — a DB trigger (migration 20260504120000_audit_log_append_only)
/// raises an exception on UPDATE or DELETE. Do not call auditLog.update,
/// .delete, .upsert, .updateMany, or .deleteMany — they will fail at runtime.
model AuditLog {
  id                 String    @id @default(cuid())
  timestamp          DateTime  @default(now())
  actor_id           String?
  action_type        String
  entity_type        String
  entity_id          String
  ip_address         String?
  user_agent         String?
  metadata           Json
  blob_replicated_at DateTime?
  actor              User?     @relation(fields: [actor_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([actor_id])
  @@index([timestamp])
  @@index([action_type])
}

model Order {
  id                               String                     @id @default(cuid())
  customer_id                      String
  status                           OrderStatus                @default(PENDING_APPROVAL)
  created_at                       DateTime                   @default(now())
  updated_at                       DateTime                   @updatedAt
  task_id                          String?
  accept_deadline_at               DateTime?
  accepted_at                      DateTime?
  assigned_member_id               String?
  cancellation_reason              String?
  cancelled_at                     DateTime?
  completed_at                     DateTime?
  contractor_profile_id            String?
  contractor_user_id               String?
  currency                         CurrencyCode               @default(AUD)
  disputed_at                      DateTime?
  environment_details              Json?
  invoice_blob_path                String?
  net_payout_aud                   Decimal?                   @db.Decimal(10, 2)
  origin                           OrderOrigin
  payment_held_at                  DateTime?
  payout_status                    String?
  price                            Decimal                    @db.Decimal(10, 2)
  price_aud                        Decimal                    @db.Decimal(10, 2)
  review_deadline_at               DateTime?
  scope_snapshot                   Json
  scope_version                    Int                        @default(1)
  scoped_at                        DateTime?
  scoping_job_id                   String?
  status_history                   Json                       @default("[]")
  stripe_payment_intent_id         String?
  stripe_transfer_id               String?
  submitted_at                     DateTime?
  tax_amount_aud                   Decimal                    @default(0) @db.Decimal(10, 2)
  total_amount_aud                 Decimal                    @db.Decimal(10, 2)
  work_started_at                  DateTime?
  credential_purge_scheduled_at    DateTime?
  credentials_revoked_confirmed_at DateTime?
  company_id                       String?
  executing_member_id              String?
  company_order_status             CompanyOrderStatus?
  change_requests                  ChangeRequest[]
  company_invoice                  CompanyInvoice?
  proposals                        CompanyOrderProposal[]
  company_payout_record            CompanyPayoutRecord?
  dispute                          Dispute?
  milestone_releases               MilestoneRelease[]
  assigned_member                  OrgMember?                 @relation(fields: [assigned_member_id], references: [id])
  company                          ConsultingCompany?         @relation("CompanyOrders", fields: [company_id], references: [id])
  contractor_profile               ContractorProfile?         @relation(fields: [contractor_profile_id], references: [id])
  contractor_user                  User?                      @relation("OrderContractor", fields: [contractor_user_id], references: [id])
  customer                         User                       @relation("OrderCustomer", fields: [customer_id], references: [id])
  executing_member                 User?                      @relation("OrderExecutingMember", fields: [executing_member_id], references: [id])
  task                             Task?                      @relation(fields: [task_id], references: [id])
  credentials                      OrderAccessCredential[]
  chat_messages                    OrderChatMessage[]
  deliverables                     OrderDeliverable[]
  messages                         OrderMessage[]
  payout_record                    PayoutRecord?
  purchase_order                   PurchaseOrder?
  rating                           Rating?
  scope_modification_requests      ScopeModificationRequest[]
  work_logs                        WorkLog[]
  bank_transfer_payment            BankTransferPayment?
  service_invoices                 ServiceInvoice[]           @relation("ServiceInvoiceOrder")

  // ── Direct-payment fields (Phase 2: subscription-only marketplace) ─────────
  // Populated when the customer reports an out-of-band payment and the
  // supplier confirms receipt. Only used for orders created on/after the
  // direct-payment cutover; pre-cutover orders continue to use the legacy
  // escrow path (stripe_payment_intent_id / payout_record / etc.).
  payment_method              PaymentMethod?
  payment_reference           String?
  payment_amount_reported_aud Decimal?       @db.Decimal(10, 2)
  customer_reported_paid_at   DateTime?
  supplier_confirmed_paid_at  DateTime?
  payment_evidence_blob_path  String?
  payment_evidence_file_name  String?
  payment_dispute_reason      String?
  payment_dispute_raised_at   DateTime?
  // Append-only log of every evidence the customer has reported. Each entry
  // is an OrderPaymentEvidenceEntry (see packages/shared) with id, blob_path,
  // file_name, uploaded_at, payment_method/reference/amount, status, and
  // (when REJECTED) the supplier's dispute_reason. The legacy
  // payment_evidence_blob_path/file_name fields above always point at the
  // most recent entry for back-compat.
  payment_evidence_history    Json           @default("[]")

  @@index([customer_id])
  @@index([contractor_user_id])
  @@index([contractor_profile_id])
  @@index([task_id])
  @@index([status])
  @@index([assigned_member_id])
  @@index([company_id])
  @@index([executing_member_id])
}

model Organisation {
  id                     String                    @id @default(cuid())
  entity_name            String
  registration_number    String?
  country                String                    @default("AU")
  abn                    String?
  address                String?
  contact_email          String
  logo_blob_path         String?
  verification_status    OrgVerificationStatus     @default(INCOMPLETE)
  verified_at            DateTime?
  verified_by            String?
  rejection_reason       String?
  stripe_account_id      String?
  stripe_account_enabled Boolean                   @default(false)
  insurance_tier_met     Boolean                   @default(false)
  agreement_accepted_at  DateTime?
  agreement_version      String?
  agreement_ip_address   String?
  agreement_user_agent   String?
  suspended_at           DateTime?
  suspension_reason      String?
  created_at             DateTime                  @default(now())
  updated_at             DateTime                  @updatedAt
  admin_user_id          String
  documents              OrgDocument[]
  insurance_certificates OrgInsuranceCertificate[]
  legal_acceptances      OrgLegalAcceptance[]
  members                OrgMember[]
  admin_user             User                      @relation("OrgCreator", fields: [admin_user_id], references: [id])
  tasks                  Task[]

  @@index([admin_user_id])
  @@index([verification_status])
  @@index([abn])
}

model OrgMember {
  id                     String          @id @default(cuid())
  org_id                 String
  user_id                String?
  role                   OrgMemberRole   @default(ORG_MEMBER)
  status                 OrgMemberStatus @default(INVITED)
  invited_email          String
  invitation_token_hash  String?
  invitation_expires_at  DateTime?
  invitation_accepted_at DateTime?
  invited_by_user_id     String?
  identity_status        String          @default("NOT_STARTED")
  kyc_status             String          @default("NOT_STARTED")
  active_order_count     Int             @default(0)
  joined_at              DateTime?
  removed_at             DateTime?
  removal_reason         String?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  assigned_orders        Order[]
  organisation           Organisation    @relation(fields: [org_id], references: [id])
  user                   User?           @relation(fields: [user_id], references: [id])

  @@unique([org_id, invited_email])
  @@unique([org_id, user_id])
  @@index([org_id])
  @@index([user_id])
  @@index([invitation_token_hash])
  @@index([status])
}

model OrgDocument {
  id                  String       @id @default(cuid())
  org_id              String
  doc_type            String
  blob_path           String
  file_name           String
  uploaded_by_user_id String
  reviewed_at         DateTime?
  reviewed_by         String?
  review_notes        String?
  created_at          DateTime     @default(now())
  organisation        Organisation @relation(fields: [org_id], references: [id])

  @@index([org_id])
}

model OrgLegalAcceptance {
  id            String       @id @default(cuid())
  org_id        String
  accepted_by   String
  document_type String
  version       String
  accepted_at   DateTime     @default(now())
  ip_address    String?
  user_agent    String?
  organisation  Organisation @relation(fields: [org_id], references: [id])

  @@unique([org_id, document_type, version])
  @@index([org_id])
}

model OrgInsuranceCertificate {
  id                    String          @id @default(cuid())
  org_id                String
  insurer_name          String
  policy_number         String
  insurance_type        InsuranceType
  coverage_amount_aud   Decimal         @db.Decimal(12, 2)
  policy_start_date     DateTime
  policy_expiry_date    DateTime
  worldwide_coverage    Boolean         @default(false)
  tier                  InsuranceTier
  certificate_blob_path String
  status                InsuranceStatus @default(PENDING_REVIEW)
  reviewed_by           String?
  reviewed_at           DateTime?
  rejection_reason      String?
  verified_at           DateTime?
  expired_at            DateTime?
  expiry_reminder_sent  Int             @default(0)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  organisation          Organisation    @relation(fields: [org_id], references: [id])

  @@index([org_id])
  @@index([status])
  @@index([policy_expiry_date])
}

model VideoSession {
  id                         String                   @id @default(cuid())
  session_type               SessionType
  room_name                  String                   @unique
  host_user_id               String
  participant_user_id        String
  contractor_profile_id      String?
  order_id                   String?
  host_consent_at            DateTime?
  participant_consent_at     DateTime?
  livekit_room_name          String?
  egress_id                  String?
  recording_blob_path        String?
  recording_duration_s       Int?
  status                     SessionStatus            @default(SCHEDULED)
  scheduled_at               DateTime
  started_at                 DateTime?
  recording_started_at       DateTime?
  ended_at                   DateTime?
  cancellation_reason        String?
  kyc_outcome                KycOutcome?
  kyc_outcome_notes          String?
  kyc_reviewed_by            String?
  kyc_reviewed_at            DateTime?
  // Reschedule-request flow (contractor proposes a different time;
  // admin approves or rejects). Only meaningful while status=SCHEDULED.
  // reschedule_request_status NULL  = no active request
  //                           PENDING_REVIEW = contractor proposed, awaiting admin
  //                           APPROVED       = admin accepted (scheduled_at moved)
  //                           REJECTED       = admin declined (scheduled_at unchanged)
  reschedule_request_status  RescheduleRequestStatus?
  reschedule_proposed_at     DateTime?
  reschedule_comment         String?
  reschedule_requested_by_id String?
  reschedule_requested_at    DateTime?
  reschedule_decided_by_id   String?
  reschedule_decided_at      DateTime?
  reschedule_admin_notes     String?
  created_at                 DateTime                 @default(now())
  updated_at                 DateTime                 @updatedAt
  contractor_profile         ContractorProfile?       @relation(fields: [contractor_profile_id], references: [id])
  host_user                  User                     @relation("SessionHost", fields: [host_user_id], references: [id])
  participant_user           User                     @relation("SessionParticipant", fields: [participant_user_id], references: [id])

  @@index([contractor_profile_id])
  @@index([host_user_id])
  @@index([participant_user_id])
  @@index([status])
  @@index([scheduled_at])
}

