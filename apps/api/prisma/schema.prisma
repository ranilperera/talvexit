model Notification {
  id         String               @id @default(cuid())
  user_id    String
  category   NotificationCategory
  title      String
  body       String?
  link_url   String?
  metadata   Json?
  read_at    DateTime?
  created_at DateTime             @default(now())
  user       User                 @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([user_id, read_at])
}

enum NotificationCategory {
  ORDER
  PAYMENT
  DISPUTE
  TENDER
  ACCOUNT
  MESSAGE
  COMPLIANCE
  ADMIN
  MARKETING
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUBSCRIPTION MODULE
// ═══════════════════════════════════════════════════════════════════════════════

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  PAUSED
  UNPAID
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PlanType {
  CUSTOMER_STARTER
  CUSTOMER_BUSINESS
  CUSTOMER_PROFESSIONAL
  CUSTOMER_ENTERPRISE
  SUPPLIER_FREE
  SUPPLIER_SOLO
  SUPPLIER_COMPANY_STARTER
  SUPPLIER_COMPANY_PRO
  SUPPLIER_GLOBAL
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER_BSB
  BANK_TRANSFER_SWIFT
  WISE
  OTHER
}

enum PaymentEvidenceStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

// ── SUBSCRIPTION PLAN (admin-configured) ─────────────────────────────────────
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  plan_type   PlanType
  is_active   Boolean  @default(true)
  is_public   Boolean  @default(true)
  sort_order  Int      @default(0)

  // Pricing
  monthly_price_aud Decimal? @db.Decimal(10, 2)
  yearly_price_aud  Decimal? @db.Decimal(10, 2)
  monthly_price_usd Decimal? @db.Decimal(10, 2)
  yearly_price_usd  Decimal? @db.Decimal(10, 2)
  trial_days        Int      @default(0)

  // Stripe Price IDs (set by admin after creating in Stripe Dashboard)
  stripe_price_id_monthly String?
  stripe_price_id_yearly  String?
  stripe_product_id       String?

  // Feature limits (null = unlimited for customer plans; supplier plans use
  // hard caps post-rebuild). See docs/supplier-subscription-plan.html.
  max_active_tasks             Int?
  max_team_seats               Int?
  max_bids_per_month           Int?
  max_domain_categories        Int?
  max_ai_requests_per_month    Int?
  allowed_listing_items        Int?
  max_orders_per_month         Int?
  max_active_tenders           Int?
  max_active_orders            Int?
  max_active_contracts         Int?
  // Customer-side additions — see docs/customer-subscription-plan.html
  max_task_bookings_per_month  Int?
  max_contracts_per_month      Int?
  // Quota 7 — manually-authored tenders (no AI cost). Counter-backed,
  // monthly reset. ai_scopes still gates AI-generated tenders & orders.
  max_manual_tenders_per_month Int?

  // Feature flags
  allow_overseas_contractors Boolean @default(false)
  allow_project_mode         Boolean @default(false)
  allow_api_access           Boolean @default(false)
  allow_priority_listing     Boolean @default(false)
  allow_advanced_analytics   Boolean @default(false)
  allow_custom_sla           Boolean @default(false)
  allow_whitelabel           Boolean @default(false)
  allow_sso                  Boolean @default(false)
  allow_bulk_po              Boolean @default(false)
  allow_compliance_docs      Boolean @default(false)
  allow_dedicated_manager    Boolean @default(false)
  allow_video_facility       Boolean @default(false)

  // Custom features (admin-extensible)
  custom_features Json? @default("[]")

  // Marketing copy
  badge_text      String?
  cta_text        String?
  highlight_color String?

  subscriptions Subscription[]
  addons        PlanAddon[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([plan_type])
  @@index([is_active, is_public])
  @@map("subscription_plans")
}

// ── PLAN ADD-ONS (admin-configured) ──────────────────────────────────────────
model PlanAddon {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  price_aud       Decimal  @db.Decimal(10, 2)
  price_usd       Decimal? @db.Decimal(10, 2)
  stripe_price_id String?
  is_active       Boolean  @default(true)

  // What the addon grants
  additional_tasks       Int?
  additional_seats       Int?
  additional_profiles    Int?
  additional_ai_requests Int?
  feature_flag           String?

  // Plans this addon is offered with (implicit M2M)
  available_for_plans SubscriptionPlan[]

  addon_purchases AddonPurchase[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("plan_addons")
}

// ── USER / COMPANY SUBSCRIPTION ──────────────────────────────────────────────
model Subscription {
  id               String             @id @default(cuid())
  status           SubscriptionStatus @default(INACTIVE)
  billing_interval BillingInterval    @default(MONTHLY)

  // Stripe
  stripe_customer_id          String?
  stripe_subscription_id      String?   @unique
  stripe_current_period_start DateTime?
  stripe_current_period_end   DateTime?
  stripe_cancel_at_period_end Boolean   @default(false)
  stripe_trial_end            DateTime?

  // Effective limits snapshot (copied from plan, can override)
  effective_limits Json?

  // Usage tracking — counter columns reset to 0 at every period boundary.
  // Period boundaries follow the subscription anniversary (period_start +
  // 1 month, calendar-aware). The reset is performed lazily inside
  // SubscriptionService.rolloverIfDue() — no cron required.
  current_task_count          Int       @default(0) // supplier-side: tasks published
  current_project_count       Int       @default(0)
  current_bid_count           Int       @default(0) // supplier-side: tender bids
  current_ai_request_count    Int       @default(0) // customer-side: AI scopes
  current_order_count         Int       @default(0) // customer-side: total orders
  current_tender_count        Int       @default(0) // legacy — kept for back-compat
  // Customer-side counters added with the customer subscription rebuild
  current_task_booking_count  Int       @default(0) // customer Quota 1
  current_contract_count      Int       @default(0) // customer Quota 5
  current_manual_tender_count Int       @default(0) // customer Quota 7 — manual tenders
  usage_reset_at              DateTime?

  // Anniversary period boundaries — used by the lazy rollover. Set on
  // subscription creation; period_end is recalculated each rollover.
  period_start DateTime?
  period_end   DateTime?

  // Relations
  plan       SubscriptionPlan   @relation(fields: [plan_id], references: [id])
  plan_id    String
  user       User?              @relation(fields: [user_id], references: [id])
  user_id    String?            @unique
  company    ConsultingCompany? @relation(fields: [company_id], references: [id])
  company_id String?            @unique

  invoices        Invoice[]
  addon_purchases AddonPurchase[]
  usage_history   SubscriptionUsageHistory[]

  started_at   DateTime?
  cancelled_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([status])
  @@index([stripe_customer_id])
  @@map("subscriptions")
}

// ── SUBSCRIPTION USAGE HISTORY ──────────────────────────────────────────────
// Archive of every closed billing period, written by SubscriptionService.
// rolloverIfDue() the moment a period_end is crossed. Snapshots both the
// counters consumed and the limits in force at the time so the customer
// can see accurate historical numbers across plan upgrades / downgrades.
//
// Retention: 36 months. A daily prune job removes rows older than that.
model SubscriptionUsageHistory {
  id                   String       @id @default(cuid())
  subscription         Subscription @relation(fields: [subscription_id], references: [id])
  subscription_id      String
  // Snapshotted plan reference — plan can change between periods, the
  // history row needs to reflect what was in force at the time.
  plan_id              String
  plan_name            String
  period_start         DateTime
  period_end           DateTime
  // Counters consumed during the closed period
  task_bookings_used   Int          @default(0)
  orders_used          Int          @default(0)
  ai_scopes_used       Int          @default(0)
  contracts_used       Int          @default(0)
  manual_tenders_used  Int          @default(0)
  // Limits as they were on the plan at the time (null = unlimited)
  task_bookings_limit  Int?
  orders_limit         Int?
  ai_scopes_limit      Int?
  contracts_limit      Int?
  manual_tenders_limit Int?
  archived_at          DateTime     @default(now())

  @@index([subscription_id, period_end])
  @@map("subscription_usage_history")
}

// ── ADDON PURCHASES ──────────────────────────────────────────────────────────
model AddonPurchase {
  id                String       @id @default(cuid())
  subscription      Subscription @relation(fields: [subscription_id], references: [id])
  subscription_id   String
  addon             PlanAddon    @relation(fields: [addon_id], references: [id])
  addon_id          String
  stripe_payment_id String?
  quantity          Int          @default(1)
  purchased_at      DateTime     @default(now())
  expires_at        DateTime?

  @@index([subscription_id])
  @@index([addon_id])
  @@map("addon_purchases")
}

// ── PLATFORM INVOICE (subscription billing) ──────────────────────────────────
model Invoice {
  id             String        @id @default(cuid())
  invoice_number String        @unique
  status         InvoiceStatus @default(DRAFT)

  // Parties
  subscription         Subscription       @relation(fields: [subscription_id], references: [id])
  subscription_id      String
  billed_to_user       User?              @relation("InvoiceBilledToUser", fields: [billed_to_user_id], references: [id])
  billed_to_user_id    String?
  billed_to_company    ConsultingCompany? @relation("InvoiceBilledToCompany", fields: [billed_to_company_id], references: [id])
  billed_to_company_id String?

  // Stripe
  stripe_invoice_id        String? @unique
  stripe_payment_intent_id String?

  // Amounts (AUD unless overridden)
  currency          String @default("AUD")
  subtotal_cents    Int
  tax_cents         Int    @default(0)
  total_cents       Int
  amount_paid_cents Int    @default(0)

  // Tax (AU GST default)
  tax_rate           Decimal @default(0.1000) @db.Decimal(5, 4)
  tax_description    String  @default("GST 10%")
  tax_invoice_number String?

  // Content
  line_items           Json
  billing_period_start DateTime?
  billing_period_end   DateTime?
  due_date             DateTime?
  paid_at              DateTime?
  notes                String?

  // PDF
  pdf_storage_url  String?
  pdf_generated_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([subscription_id])
  @@index([status])
  @@index([billed_to_user_id])
  @@index([billed_to_company_id])
  @@map("invoices")
}

// ── SERVICE PROVIDER → CLIENT INVOICE (direct B2B invoicing) ─────────────────
model ServiceInvoice {
  id             String        @id @default(cuid())
  invoice_number String        @unique
  status         InvoiceStatus @default(DRAFT)

  // Parties
  from_user       User               @relation("ServiceInvoiceFrom", fields: [from_user_id], references: [id])
  from_user_id    String
  to_user         User               @relation("ServiceInvoiceTo", fields: [to_user_id], references: [id])
  to_user_id      String
  from_company    ConsultingCompany? @relation("ServiceInvoiceFromCompany", fields: [from_company_id], references: [id])
  from_company_id String?
  to_company      ConsultingCompany? @relation("ServiceInvoiceToCompany", fields: [to_company_id], references: [id])
  to_company_id   String?

  // Task / Order reference (Project model not yet defined → plain id)
  task       Task?   @relation("ServiceInvoiceTask", fields: [task_id], references: [id])
  task_id    String?
  order      Order?  @relation("ServiceInvoiceOrder", fields: [order_id], references: [id])
  order_id   String?
  project_id String?

  // Amounts
  currency          String @default("AUD")
  subtotal_cents    Int
  tax_cents         Int    @default(0)
  total_cents       Int
  amount_paid_cents Int    @default(0)

  // Tax (supplier's GST)
  supplier_abn            String?
  supplier_gst_registered Boolean  @default(false)
  tax_rate                Decimal? @db.Decimal(5, 4)
  tax_description         String?

  // Line items
  line_items Json
  notes      String?
  terms      String?
  due_date   DateTime?
  paid_at    DateTime?

  // Payment
  agreed_payment_method PaymentMethod?
  payment_instructions  Json?
  payment_evidence      PaymentEvidence[]

  // PDF
  pdf_storage_url  String?
  pdf_generated_at DateTime?

  // Stripe (if client pays via Stripe)
  stripe_payment_intent_id String?

  // Phase 5.2 — magic-link public access + overdue tracking
  public_view_token_hash String?   @unique
  last_reminder_sent_at  DateTime?

  sent_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([from_user_id])
  @@index([to_user_id])
  @@index([from_company_id])
  @@index([to_company_id])
  @@index([task_id])
  @@index([order_id])
  @@index([status])
  @@map("service_invoices")
}

// ── PAYMENT EVIDENCE (client submits proof of payment) ───────────────────────
model PaymentEvidence {
  id                   String         @id @default(cuid())
  service_invoice      ServiceInvoice @relation(fields: [service_invoice_id], references: [id])
  service_invoice_id   String
  submitted_by         User           @relation("PaymentEvidenceSubmitter", fields: [submitted_by_user_id], references: [id])
  submitted_by_user_id String

  payment_method    PaymentMethod
  payment_reference String?
  payment_date      DateTime
  amount_cents      Int
  currency          String        @default("AUD")
  notes             String?

  // File evidence (bank screenshot, receipt etc.)
  evidence_file_url  String?
  evidence_file_name String?

  status              PaymentEvidenceStatus @default(SUBMITTED)
  reviewed_by         User?                 @relation("PaymentEvidenceReviewer", fields: [reviewed_by_user_id], references: [id])
  reviewed_by_user_id String?
  reviewed_at         DateTime?
  rejection_reason    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([service_invoice_id])
  @@index([status])
  @@map("payment_evidence")
}

// ─── CONTACT ENQUIRY ──────────────────────────────────────────────────────────
// Public contact-form submissions plus the admin response thread. Every
// /contact submission persists here before the email worker fires (the old
// fire-and-forget queue-only path silently dropped jobs because the worker
// had no handler — see commit message of this migration).

enum ContactEnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

model ContactEnquiry {
  id           String  @id @default(cuid())
  // Submission fields (everything the form collects + audit metadata)
  name         String
  email        String
  phone        String?
  enquiry_type String
  message      String  @db.Text
  ip_address   String?
  user_agent   String?

  // Triage state
  status               ContactEnquiryStatus @default(NEW)
  admin_notes          String?              @db.Text
  responded_at         DateTime?
  responded_by_user_id String?
  responded_by         User?                @relation("ContactEnquiryResponder", fields: [responded_by_user_id], references: [id])

  responses ContactEnquiryResponse[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status, created_at])
  @@index([email])
  @@map("contact_enquiries")
}

model ContactEnquiryResponse {
  id              String         @id @default(cuid())
  enquiry         ContactEnquiry @relation(fields: [enquiry_id], references: [id], onDelete: Cascade)
  enquiry_id      String
  // Admin who composed the reply
  sent_by_user_id String
  sent_by         User           @relation("ContactEnquiryResponseAuthor", fields: [sent_by_user_id], references: [id])

  subject String
  body    String   @db.Text
  // Snapshot of the email payload at send time — useful for audit and for
  // building "view sent message" in the admin UI without re-querying.
  sent_at DateTime @default(now())

  @@index([enquiry_id, sent_at])
  @@map("contact_enquiry_responses")
}
