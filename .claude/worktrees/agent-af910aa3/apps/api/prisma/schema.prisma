// Prisma schema for onys.online

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum AccountType {
  CUSTOMER
  INDIVIDUAL_CONTRACTOR
  ORGANIZATION_ADMIN
  ORG_MEMBER
  PLATFORM_ADMIN
  SUPPORT_ADMIN
  COMPLIANCE_ADMIN
}

enum ContractorStatus {
  INCOMPLETE
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum IdentityStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum InsuranceTier {
  STANDARD
  ELEVATED
  HIGH_RISK
  ORGANIZATION
}

enum InsuranceStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
  SUSPENDED
  SUPERSEDED
}

enum InsuranceType {
  PI
  PL
  CYBER
}

enum KycStatus {
  NOT_STARTED
  SCHEDULED
  COMPLETED_PENDING_REVIEW
  APPROVED
  REJECTED
  REQUIRES_INFO
}

enum Domain {
  FIREWALL
  NETWORKING
  DATABASE
  CLOUD_AZURE
  LINUX
  WINDOWS_ADMIN
  CYBERSECURITY
  DEVOPS
  STORAGE
  VIRTUALIZATION
  OFFICE_365
  BACKUP
  AI_INTEGRATION
  SYSTEM_ADMIN
}

enum TaskStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING_APPROVAL
  SCOPED
  ACCEPTED
  PAYMENT_HELD
  IN_PROGRESS
  PENDING_REVIEW
  REVISION_REQUESTED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum OrderOrigin {
  CATALOG_TASK  // customer booked from published task
  AI_SCOPED     // customer used AI scoping wizard
}

enum SessionType {
  VIDEO_KYC
  PRE_TASK_SCOPING
  ORDER_KICKOFF
  MILESTONE_CHECK_IN
  DELIVERY_WALKTHROUGH
  DISPUTE_REVIEW
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  RECORDING
  COMPLETED
  CANCELLED
  FAILED
}

enum KycOutcome {
  APPROVED
  REJECTED
  INCONCLUSIVE
}

enum DisputeGrounds {
  DELIVERABLES_NOT_AS_SCOPED
  WORK_ABANDONED
  ACCESS_EXCEEDED
  CUSTOMER_WITHHOLDING_APPROVAL
  SCOPE_MISREPRESENTATION
  DATA_BREACH
}

enum DisputeOutcome {
  FULL_PAYMENT
  PARTIAL_PAYMENT
  FULL_REFUND
  REMEDY_REQUIRED
}

enum DisputeStatus {
  OPEN           // just filed — awaiting admin assignment
  ASSIGNED       // admin assigned
  UNDER_REVIEW   // arbitrator appointed or active review
  DETERMINED     // outcome issued
  CLOSED         // payment action completed
}

enum RatingTag {
  CLEAR_SCOPE
  FAST_DELIVERY
  GREAT_DOCS
  RESPONSIVE
  WENT_ABOVE_SCOPE  // positive
  LATE_DELIVERY
  POOR_DOCS
  SCOPE_CREEP
  UNRESPONSIVE      // negative
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  DECLINED
  EXPIRED
}

enum DeliverableStatus {
  UPLOADED
  ACCEPTED
  REJECTED
}

enum ScopingJobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum AmlCheckType {
  PEP
  SANCTIONS
  EDD
}

enum EmploymentType {
  SOLE_TRADER
  EMPLOYED_WITH_PERMISSION
  EMPLOYED_NO_RESTRICTION
  BUSINESS_ENTITY
}

enum CredentialType {
  SSH_KEY
  PASSWORD
  API_KEY
  VPN_CONFIG
  OTHER
}

// CredentialAccessEvent removed — event_type stored as String in CredentialAccessLog
// Values: STORED, RETRIEVED, DELETED, PURGED

enum OrgMemberRole {
  ORG_ADMIN
  ORG_MEMBER
}

enum OrgVerificationStatus {
  INCOMPLETE
  PENDING_REVIEW
  VERIFIED
  SUSPENDED
  REJECTED
}

enum OrgMemberStatus {
  INVITED
  PENDING
  VERIFIED
  INACTIVE
  REMOVED
}

enum ScopeElementType {
  ACTIVITY
  ASSUMPTION
  DELIVERABLE
  PRICE
  HOURS
  MILESTONE
}

enum SmrResponse {
  ACCEPT
  ACCEPT_WITH_REVISION
  DECLINE
}

enum SmrStatus {
  PENDING
  RESPONDED
  EXPIRED
}

enum CurrencyCode {
  AUD
  USD
  GBP
  EUR
  NZD
  SGD
  CAD
}

enum StripeConnectStatus {
  PENDING       // account created, onboarding not complete
  ENABLED       // charges and payouts enabled
  RESTRICTED    // payouts disabled — needs action
  DEAUTHORIZED  // contractor disconnected their Stripe account
}

enum PayoutStatus {
  PENDING    // order completed, payout not yet initiated
  INITIATED  // Transfer created in Stripe
  COMPLETED  // transfer.paid webhook received
  FAILED     // transfer failed
  ON_HOLD    // disputed or admin hold
}

enum MilestoneReleaseStatus {
  PENDING     // milestone not yet approved
  APPROVED    // customer approved milestone
  TRANSFERRED // Stripe Transfer created
  FAILED      // transfer failed
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  password_hash      String
  account_type       AccountType
  full_name          String
  email_verified     Boolean     @default(false)
  email_verified_at  DateTime?
  mfa_enabled        Boolean     @default(false)
  mfa_secret         String?
  mfa_backup_codes   Json        @default("[]")
  account_locked     Boolean     @default(false)
  locked_until       DateTime?
  failed_login_count Int         @default(0)
  last_login_at      DateTime?
  email_verification_token    String?
  email_verification_expires  DateTime?
  password_reset_token        String?
  password_reset_expires      DateTime?
  created_at                  DateTime    @default(now())
  updated_at                  DateTime    @updatedAt
  deleted_at                  DateTime?

  refresh_tokens          RefreshToken[]
  contractor_profile      ContractorProfile?
  customer_profile        CustomerProfile?
  legal_acceptances       LegalDocAcceptance[]
  audit_logs              AuditLog[]
  orders_as_customer      Order[]          @relation("OrderCustomer")
  orders_as_contractor    Order[]          @relation("OrderContractor")
  sessions_as_host        VideoSession[]   @relation("SessionHost")
  sessions_as_participant VideoSession[]   @relation("SessionParticipant")
  created_organisations   Organisation[]   @relation("OrgCreator")
  org_memberships         OrgMember[]
  tasks                   Task[]
  smr_requests            ScopeModificationRequest[] @relation("SmrRequester")
  smr_responses           ScopeModificationRequest[] @relation("SmrResponder")
  work_logs               WorkLog[]
  deliverables_uploaded   OrderDeliverable[]
  change_requests_raised  ChangeRequest[]  @relation("ChangeRequestRaiser")
  change_requests_decided ChangeRequest[]  @relation("ChangeRequestDecider")
  disputes_raised         Dispute[]        @relation("DisputeRaiser")
  administered_disputes   Dispute[]        @relation("DisputeAdmin")
  determined_disputes     Dispute[]        @relation("DisputeDeterminer")
  ratings_submitted       Rating[]         @relation("RatingSubmitter")
  dispute_submissions     DisputeSubmission[]
  pending_scopes          PendingScope[]
  credentials_stored      OrderAccessCredential[] @relation("CredentialStorer")
  aml_checks_received     AmlCheck[]              @relation("AmlSubject")
  aml_checks_triggered    AmlCheck[]              @relation("AmlTrigger")
  aml_checks_reviewed     AmlCheck[]              @relation("AmlReviewer")

  @@index([email])
  @@index([account_type])
  @@index([email_verification_token])
  @@index([password_reset_token])
}

model ContractorProfile {
  id                     String           @id @default(cuid())
  user_id                String           @unique
  status                 ContractorStatus @default(INCOMPLETE)
  onboarding_step        Int              @default(1)

  // Step 1 — Personal Info
  bio                    String?
  linkedin_url           String?
  timezone               String?
  phone                  String?

  // Step 2 — Employment Declaration
  employment_type        EmploymentType?
  employer_name          String?
  has_employer_consent   Boolean?
  employment_declared_at DateTime?

  // Step 3 — Domains & Skills
  domains                Domain[]
  skills                 String[]

  // Step 4 — Rates & Availability
  hourly_rate_aud              Decimal? @db.Decimal(10, 2)
  availability_hours_per_week  Int?
  available_from               DateTime?

  // Step 5 — Identity Upload
  identity_document_type       String?
  identity_document_blob_path  String?
  identity_status              IdentityStatus @default(NOT_STARTED)

  // Step 7 — Agreement Acceptance
  agreement_accepted_at  DateTime?
  agreement_version      String?

  // Stripe / Payments
  stripe_account_id      String?
  stripe_account_enabled Boolean          @default(false)

  // Stats
  completed_orders_count Int              @default(0)
  overall_rating         Decimal?         @db.Decimal(3, 1)
  rating_count           Int              @default(0)
  kyc_status             KycStatus        @default(NOT_STARTED)
  insurance_tier_met     Boolean          @default(false)

  // Lifecycle audit
  activated_at           DateTime?
  suspended_at           DateTime?
  suspension_reason      String?
  banned_at              DateTime?
  ban_reason             String?

  created_at             DateTime         @default(now())
  updated_at             DateTime         @updatedAt

  user                   User               @relation(fields: [user_id], references: [id])
  agreements             ContractorAgreement[]
  insurance_certificates InsuranceCertificate[]
  video_sessions         VideoSession[]
  tasks                  Task[]
  orders                 Order[]
  stripe_connect_account StripeConnectAccount?
  payout_records         PayoutRecord[]
  ratings                Rating[]
  arbitrator_disputes    Dispute[]          @relation("DisputeArbitrator")

  @@index([status])
  @@index([domains])
}

model InsuranceCertificate {
  id                   String            @id @default(cuid())
  contractor_id        String
  contractor           ContractorProfile @relation(fields: [contractor_id], references: [id])

  // Certificate details
  insurer_name         String
  policy_number        String
  insurance_type       InsuranceType
  coverage_amount_aud  Decimal           @db.Decimal(12, 2)
  policy_start_date    DateTime
  policy_expiry_date   DateTime
  worldwide_coverage   Boolean           @default(false)

  // Tier this certificate contributes to
  tier                 InsuranceTier

  // File storage
  certificate_blob_path String

  // Review workflow
  status               InsuranceStatus   @default(PENDING_REVIEW)
  reviewed_by          String?
  reviewed_at          DateTime?
  rejection_reason     String?
  admin_notes          String?

  // Lifecycle
  verified_at          DateTime?
  expired_at           DateTime?
  superseded_at        DateTime?
  expiry_reminder_sent Int               @default(0)

  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  @@index([contractor_id])
  @@index([status])
  @@index([policy_expiry_date])
}

model ContractorAgreement {
  id              String            @id @default(cuid())
  contractor_id   String
  document_type   String            // CONTRACTOR_AGREEMENT
  version         String
  accepted_at     DateTime          @default(now())
  ip_address      String?
  user_agent      String?
  blob_path       String?           // path to signed PDF copy in Azure Blob

  contractor      ContractorProfile @relation(fields: [contractor_id], references: [id])

  @@index([contractor_id])
}

model CustomerProfile {
  id           String   @id @default(cuid())
  user_id      String   @unique
  company_name String?
  abn          String?
  country      String   @default("AU")
  phone        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user         User     @relation(fields: [user_id], references: [id])
}

model RefreshToken {
  id         String    @id @default(cuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  revoked_at DateTime?
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([token_hash])
}



model LegalDocAcceptance {
  id            String   @id @default(cuid())
  user_id       String
  document_type String
  version       String
  accepted_at   DateTime @default(now())
  ip_address    String
  user_agent    String?

  user          User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, document_type, version])
}

// APPEND ONLY — DB trigger prevents UPDATE and DELETE
model AuditLog {
  id                 String    @id @default(cuid())
  timestamp          DateTime  @default(now())
  actor_id           String?
  action_type        String
  entity_type        String
  entity_id          String
  ip_address         String?
  user_agent         String?
  metadata           Json
  blob_replicated_at DateTime?

  actor              User?     @relation(fields: [actor_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([actor_id])
  @@index([timestamp])
  @@index([action_type])
}

// ─────────────────────────────────────────────
// M07 — ORDER LIFECYCLE
// ─────────────────────────────────────────────

model Order {
  id                       String             @id @default(cuid())

  // Origin
  origin                   OrderOrigin
  task_id                  String?
  task                     Task?              @relation(fields: [task_id], references: [id])
  scoping_job_id           String?            // from M08 AI scoping

  // Parties
  customer_id              String
  customer                 User               @relation("OrderCustomer", fields: [customer_id], references: [id])
  contractor_profile_id    String?
  contractor_profile       ContractorProfile? @relation(fields: [contractor_profile_id], references: [id])
  contractor_user_id       String?
  contractor_user          User?              @relation("OrderContractor", fields: [contractor_user_id], references: [id])

  // For org orders — which member is assigned
  assigned_member_id       String?
  assigned_member          OrgMember?         @relation(fields: [assigned_member_id], references: [id])

  // Scope snapshot — frozen at order creation, immutable thereafter
  scope_snapshot           Json
  scope_version            Int                @default(1)

  // Pricing — original currency + AUD equivalent
  currency                 CurrencyCode       @default(AUD)
  price                    Decimal            @db.Decimal(10, 2)
  price_aud                Decimal            @db.Decimal(10, 2)
  tax_amount_aud           Decimal            @db.Decimal(10, 2) @default(0)
  total_amount_aud         Decimal            @db.Decimal(10, 2)

  // Customer environment details
  environment_details      Json?

  // State machine
  status                   OrderStatus        @default(PENDING_APPROVAL)
  status_history           Json               @default("[]")

  // SLA timestamps
  scoped_at                DateTime?
  accepted_at              DateTime?
  payment_held_at          DateTime?
  work_started_at          DateTime?
  submitted_at             DateTime?
  review_deadline_at       DateTime?          // submitted_at + 72h
  completed_at             DateTime?
  cancelled_at             DateTime?
  cancellation_reason      String?
  disputed_at              DateTime?

  // Accept window SLA (scoped_at + 48h)
  accept_deadline_at       DateTime?

  // Payment (populated by M09)
  stripe_payment_intent_id String?
  stripe_transfer_id       String?
  payout_status            String?
  net_payout_aud           Decimal?           @db.Decimal(10, 2)
  invoice_blob_path        String?

  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt

  // Relations
  work_logs                WorkLog[]
  deliverables             OrderDeliverable[]
  change_requests          ChangeRequest[]
  scope_modification_requests ScopeModificationRequest[]
  dispute                  Dispute?
  rating                   Rating?
  payout_record            PayoutRecord?
  milestone_releases       MilestoneRelease[]
  credentials              OrderAccessCredential[]

  // M10 — credential lifecycle
  credentials_revoked_confirmed_at DateTime?
  credential_purge_scheduled_at    DateTime?

  @@index([customer_id])
  @@index([contractor_user_id])
  @@index([contractor_profile_id])
  @@index([task_id])
  @@index([status])
  @@index([assigned_member_id])
}

// ─────────────────────────────────────────────
// M05 — ORGANISATION MODELS
// ─────────────────────────────────────────────

model Organisation {
  id                     String                @id @default(cuid())

  // Basic identity
  entity_name            String
  registration_number    String?
  country                String                @default("AU")
  abn                    String?
  address                String?
  contact_email          String
  logo_blob_path         String?

  // Verification
  verification_status    OrgVerificationStatus @default(INCOMPLETE)
  verified_at            DateTime?
  verified_by            String?
  rejection_reason       String?

  // Stripe Connect
  stripe_account_id      String?
  stripe_account_enabled Boolean               @default(false)

  // Insurance
  insurance_tier_met     Boolean               @default(false)

  // Agreement
  agreement_accepted_at  DateTime?
  agreement_version      String?
  agreement_ip_address   String?
  agreement_user_agent   String?

  // Lifecycle
  suspended_at           DateTime?
  suspension_reason      String?

  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt

  // Relations
  admin_user_id          String
  admin_user             User                  @relation("OrgCreator", fields: [admin_user_id], references: [id])
  members                OrgMember[]
  documents              OrgDocument[]
  insurance_certificates OrgInsuranceCertificate[]
  legal_acceptances      OrgLegalAcceptance[]
  tasks                  Task[]

  @@index([admin_user_id])
  @@index([verification_status])
  @@index([abn])
}

model OrgMember {
  id                      String          @id @default(cuid())

  org_id                  String
  organisation            Organisation    @relation(fields: [org_id], references: [id])

  user_id                 String?
  user                    User?           @relation(fields: [user_id], references: [id])

  role                    OrgMemberRole   @default(ORG_MEMBER)
  status                  OrgMemberStatus @default(INVITED)

  // Invitation details
  invited_email           String
  invitation_token_hash   String?
  invitation_expires_at   DateTime?
  invitation_accepted_at  DateTime?
  invited_by_user_id      String?

  // Verification tracking
  identity_status         String          @default("NOT_STARTED")
  kyc_status              String          @default("NOT_STARTED")

  // Order assignment tracking
  active_order_count      Int             @default(0)

  joined_at               DateTime?
  removed_at              DateTime?
  removal_reason          String?

  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  assigned_orders         Order[]

  @@unique([org_id, invited_email])
  @@unique([org_id, user_id])
  @@index([org_id])
  @@index([user_id])
  @@index([invitation_token_hash])
  @@index([status])
}

model OrgDocument {
  id                   String       @id @default(cuid())
  org_id               String
  organisation         Organisation @relation(fields: [org_id], references: [id])
  doc_type             String
  blob_path            String
  file_name            String
  uploaded_by_user_id  String
  reviewed_at          DateTime?
  reviewed_by          String?
  review_notes         String?
  created_at           DateTime     @default(now())

  @@index([org_id])
}

model OrgLegalAcceptance {
  id            String       @id @default(cuid())
  org_id        String
  organisation  Organisation @relation(fields: [org_id], references: [id])
  accepted_by   String
  document_type String
  version       String
  accepted_at   DateTime     @default(now())
  ip_address    String?
  user_agent    String?

  @@unique([org_id, document_type, version])
  @@index([org_id])
}

model OrgInsuranceCertificate {
  id                    String          @id @default(cuid())
  org_id                String
  organisation          Organisation    @relation(fields: [org_id], references: [id])
  insurer_name          String
  policy_number         String
  insurance_type        InsuranceType
  coverage_amount_aud   Decimal         @db.Decimal(12, 2)
  policy_start_date     DateTime
  policy_expiry_date    DateTime
  worldwide_coverage    Boolean         @default(false)
  tier                  InsuranceTier
  certificate_blob_path String
  status                InsuranceStatus @default(PENDING_REVIEW)
  reviewed_by           String?
  reviewed_at           DateTime?
  rejection_reason      String?
  verified_at           DateTime?
  expired_at            DateTime?
  expiry_reminder_sent  Int             @default(0)
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  @@index([org_id])
  @@index([status])
  @@index([policy_expiry_date])
}

model VideoSession {
  id                    String            @id @default(cuid())

  // Session classification
  session_type          SessionType
  room_name             String            @unique

  // Participants
  host_user_id          String
  host_user             User              @relation("SessionHost", fields: [host_user_id], references: [id])
  participant_user_id   String
  participant_user      User              @relation("SessionParticipant", fields: [participant_user_id], references: [id])

  // For KYC sessions
  contractor_profile_id String?
  contractor_profile    ContractorProfile? @relation(fields: [contractor_profile_id], references: [id])

  // For order sessions (Phase 3)
  order_id              String?

  // Consent tracking — both parties must confirm before recording starts
  host_consent_at       DateTime?
  participant_consent_at DateTime?

  // LiveKit details
  livekit_room_name     String?
  egress_id             String?

  // Recording output
  recording_blob_path   String?
  recording_duration_s  Int?

  // Session lifecycle
  status                SessionStatus     @default(SCHEDULED)
  scheduled_at          DateTime
  started_at            DateTime?
  recording_started_at  DateTime?
  ended_at              DateTime?
  cancellation_reason   String?

  // KYC outcome (VIDEO_KYC sessions only)
  kyc_outcome           KycOutcome?
  kyc_outcome_notes     String?
  kyc_reviewed_by       String?
  kyc_reviewed_at       DateTime?

  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  @@index([contractor_profile_id])
  @@index([host_user_id])
  @@index([participant_user_id])
  @@index([status])
  @@index([scheduled_at])
}

// ─────────────────────────────────────────────
// M06 — TASK CATALOGUE & SCOPE
// ─────────────────────────────────────────────

model Task {
  id                    String             @id @default(cuid())

  // Ownership — individual contractor OR org
  contractor_profile_id String?
  contractor_profile    ContractorProfile? @relation(fields: [contractor_profile_id], references: [id])

  org_id                String?
  organisation          Organisation?      @relation(fields: [org_id], references: [id])

  created_by_user_id    String
  created_by_user       User               @relation(fields: [created_by_user_id], references: [id])

  // Core scope fields
  title                 String
  domain                Domain
  objective             String
  in_scope              String[]
  out_of_scope          String[]
  assumptions           String[]
  prerequisites         String[]
  deliverables          String[]

  // Pricing and time
  currency              CurrencyCode       @default(AUD)
  price                 Decimal            @db.Decimal(10, 2)
  price_aud             Decimal            @db.Decimal(10, 2)
  hours_min             Int
  hours_max             Int

  // Milestones
  milestone_count       Int                @default(1)

  // Lifecycle
  status                TaskStatus         @default(DRAFT)
  published_at          DateTime?
  archived_at           DateTime?
  archive_reason        String?

  // Version control
  version               Int                @default(1)

  // Full-text search (managed by DB trigger — see m06_fulltext_search migration)
  search_vector         Unsupported("tsvector")?

  // Metrics
  view_count            Int                @default(0)
  order_count           Int                @default(0)
  active_order_count    Int                @default(0)

  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  milestones            TaskMilestone[]
  orders                Order[]
  pending_scope         PendingScope?

  @@index([status])
  @@index([domain])
  @@index([contractor_profile_id])
  @@index([org_id])
  @@index([price_aud])
  @@index([created_by_user_id])
}

model TaskMilestone {
  id                  String  @id @default(cuid())
  task_id             String
  task                Task    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  sequence            Int
  name                String
  description         String
  percentage_of_total Int

  @@unique([task_id, sequence])
  @@index([task_id])
}

model ScopeModificationRequest {
  id                   String           @id @default(cuid())

  order_id             String
  order                Order            @relation(fields: [order_id], references: [id])

  round_number         Int
  requested_by_user_id String
  requested_by_user    User             @relation("SmrRequester", fields: [requested_by_user_id], references: [id])

  // What is being changed
  element_type         ScopeElementType
  original_value       Json
  requested_value      Json
  reason               String

  // Response
  status               SmrStatus        @default(PENDING)
  responded_by_user_id String?
  responded_by_user    User?            @relation("SmrResponder", fields: [responded_by_user_id], references: [id])
  response             SmrResponse?
  response_notes       String?

  // Accept-with-revision fields
  revised_scope        Json?
  revised_price        Decimal?         @db.Decimal(10, 2)
  revised_price_aud    Decimal?         @db.Decimal(10, 2)

  responded_at         DateTime?
  expires_at           DateTime?

  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  @@index([order_id])
  @@index([status])
  @@index([requested_by_user_id])
}

model WorkLog {
  id           String   @id @default(cuid())
  order_id     String
  order        Order    @relation(fields: [order_id], references: [id])
  logged_by    String
  user         User     @relation(fields: [logged_by], references: [id])
  hours_worked Decimal  @db.Decimal(4, 2)
  description  String   // min 20 chars
  started_at   DateTime
  created_at   DateTime @default(now())

  @@index([order_id])
}

model OrderDeliverable {
  id              String            @id @default(cuid())
  order_id        String
  order           Order             @relation(fields: [order_id], references: [id])
  uploaded_by     String
  user            User              @relation(fields: [uploaded_by], references: [id])
  file_name       String
  blob_path       String
  file_size_bytes Int
  mime_type       String?
  status          DeliverableStatus @default(UPLOADED)
  description     String?
  created_at      DateTime          @default(now())

  @@index([order_id])
}

model ChangeRequest {
  id                  String              @id @default(cuid())
  order_id            String
  order               Order               @relation(fields: [order_id], references: [id])
  raised_by_user_id   String
  raised_by_user      User                @relation("ChangeRequestRaiser", fields: [raised_by_user_id], references: [id])

  description         String              // min 30 chars
  unforeseen_finding  String
  additional_hours    Int
  additional_cost     Decimal             @db.Decimal(10, 2)
  additional_cost_aud Decimal             @db.Decimal(10, 2)

  status              ChangeRequestStatus @default(PENDING)
  decided_by_user_id  String?
  decided_by_user     User?               @relation("ChangeRequestDecider", fields: [decided_by_user_id], references: [id])
  decision_notes      String?
  decided_at          DateTime?
  expires_at          DateTime

  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  @@index([order_id])
  @@index([status])
}

model Dispute {
  id                    String          @id @default(cuid())

  order_id              String          @unique
  order                 Order           @relation(fields: [order_id], references: [id])

  raised_by_user_id     String
  raised_by_user        User            @relation("DisputeRaiser", fields: [raised_by_user_id], references: [id])

  grounds               DisputeGrounds
  description           String          // min 50 chars
  evidence_blob_paths   String[]        @default([])

  // Lifecycle
  status                DisputeStatus   @default(OPEN)

  // Admin assignment
  assigned_admin_id     String?
  assigned_admin        User?           @relation("DisputeAdmin", fields: [assigned_admin_id], references: [id])
  assigned_at           DateTime?

  // Domain arbitrator — senior contractor in relevant domain
  arbitrator_profile_id String?
  arbitrator_profile    ContractorProfile? @relation("DisputeArbitrator", fields: [arbitrator_profile_id], references: [id])
  arbitrator_notes      String?
  arbitrator_notes_at   DateTime?

  // Outcome
  outcome               DisputeOutcome?
  payment_amount_aud    Decimal?        @db.Decimal(10, 2)  // if PARTIAL_PAYMENT
  written_reasons       String?         // min 100 chars
  determined_at         DateTime?
  determined_by_id      String?
  determined_by         User?           @relation("DisputeDeterminer", fields: [determined_by_id], references: [id])

  // Payment action status
  payment_action_status String?         // PENDING|COMPLETED|FAILED

  // Submission window — 72h from raised_at for both parties
  submission_window_ends_at DateTime?

  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt

  submissions           DisputeSubmission[]

  @@index([status])
  @@index([assigned_admin_id])
  @@index([grounds])
}

model DisputeSubmission {
  id                    String    @id @default(cuid())

  dispute_id            String
  dispute               Dispute   @relation(fields: [dispute_id], references: [id])

  submitted_by_user_id  String
  submitted_by_user     User      @relation(fields: [submitted_by_user_id], references: [id])

  description           String    // min 20 chars
  file_blob_paths       String[]  @default([])

  created_at            DateTime  @default(now())

  @@index([dispute_id])
}

// ─────────────────────────────────────────────
// M11 — RATINGS
// ─────────────────────────────────────────────

model Rating {
  id                    String            @id @default(cuid())

  order_id              String            @unique
  order                 Order             @relation(fields: [order_id], references: [id])

  submitted_by_user_id  String
  submitted_by_user     User              @relation("RatingSubmitter", fields: [submitted_by_user_id], references: [id])
  rated_contractor_id   String
  rated_contractor      ContractorProfile @relation(fields: [rated_contractor_id], references: [id])

  // 5-criterion scores — each 1–5
  technical_quality     Int               // weight 35%
  communication         Int               // weight 20%
  timeliness            Int               // weight 20%
  documentation_quality Int               // weight 15%
  professionalism       Int               // weight 10%

  // Calculated at submission time
  // Formula: (tq*0.35)+(comm*0.20)+(time*0.20)+(doc*0.15)+(prof*0.10)
  overall_score         Decimal           @db.Decimal(3, 1)

  // Optional written review
  review_text           String?           // max 1000 chars
  tags                  String[]          // from RatingTag enum

  // Contractor response — once within 14 days
  response_text         String?           // max 500 chars
  responded_at          DateTime?
  response_deadline_at  DateTime          // submitted_at + 14 days

  // Moderation
  is_visible            Boolean           @default(true)
  hidden_reason         String?

  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  @@index([rated_contractor_id])
  @@index([is_visible])
  @@index([created_at])
}

// ─────────────────────────────────────────────
// M08 — AI SCOPING ENGINE
// ─────────────────────────────────────────────

model PendingScope {
  id                  String           @id @default(cuid())

  // Who requested it
  customer_id         String
  customer            User             @relation(fields: [customer_id], references: [id])

  // Customer input — stored verbatim for audit + partial regen
  requirement_text    String           // raw customer requirement
  context             Json?            // { os, tools, environment, constraints }
  domain_hint         String?          // optional domain hint from customer

  // Job lifecycle
  status              ScopingJobStatus @default(PENDING)
  bullmq_job_id       String?          // BullMQ internal job ID for correlation
  attempts            Int              @default(0)
  last_error          String?

  // AI output — stored separately from accepted scope
  ai_scope_raw        String?          // raw Claude JSON response text
  ai_scope            Json?            // parsed + validated scope object

  // Customer edits — diff tracked
  accepted_scope      Json?            // final scope after customer edits
  has_customer_edits  Boolean          @default(false)
  edited_fields       String[]         @default([])

  // Section regeneration log
  regen_log           Json             @default("[]")
  // Array of { section, requested_at, completed_at, original, replacement }

  // Outcome
  accepted_at         DateTime?
  task_id             String?          @unique
  task                Task?            @relation(fields: [task_id], references: [id])

  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  @@index([customer_id])
  @@index([status])
  @@index([bullmq_job_id])
}

// ─────────────────────────────────────────────
// M09 — PAYMENTS & ESCROW
// ─────────────────────────────────────────────

model StripeConnectAccount {
  id                        String              @id @default(cuid())
  contractor_profile_id     String              @unique
  contractor_profile        ContractorProfile   @relation(fields: [contractor_profile_id], references: [id])

  stripe_account_id         String              @unique

  status                    StripeConnectStatus @default(PENDING)

  // Capability tracking from account.updated webhook
  charges_enabled           Boolean             @default(false)
  payouts_enabled           Boolean             @default(false)
  details_submitted         Boolean             @default(false)

  // Onboarding
  onboarding_url            String?
  onboarding_url_expires_at DateTime?

  // Requirements from Stripe
  requirements_due          String[]            @default([])

  country                   String              @default("AU")
  default_currency          String              @default("aud")

  account_updated_at        DateTime?

  created_at                DateTime            @default(now())
  updated_at                DateTime            @updatedAt

  @@index([stripe_account_id])
  @@index([status])
}

model PayoutRecord {
  id                    String            @id @default(cuid())

  order_id              String            @unique
  order                 Order             @relation(fields: [order_id], references: [id])

  contractor_profile_id String
  contractor_profile    ContractorProfile @relation(fields: [contractor_profile_id], references: [id])

  // Commission calculation — snapshot at payout time
  gross_amount_aud         Decimal  @db.Decimal(10, 2)
  commission_rate          Decimal  @db.Decimal(4, 3)   // e.g. 0.200, 0.170, 0.150
  commission_amount_aud    Decimal  @db.Decimal(10, 2)
  net_amount_aud           Decimal  @db.Decimal(10, 2)
  completed_orders_at_time Int

  // Stripe Transfer
  stripe_transfer_id     String?  @unique
  stripe_transfer_status String?

  // Payout to bank
  stripe_payout_id   String?
  estimated_arrival  DateTime?

  status      PayoutStatus @default(PENDING)

  initiated_at   DateTime?
  completed_at   DateTime?
  failed_at      DateTime?
  failure_reason String?

  // Invoice
  invoice_blob_path    String?
  invoice_generated_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([contractor_profile_id])
  @@index([status])
}

model MilestoneRelease {
  id             String @id @default(cuid())

  order_id       String
  order          Order  @relation(fields: [order_id], references: [id])

  milestone_sequence  Int
  milestone_name      String
  percentage_of_total Int

  gross_amount_aud      Decimal @db.Decimal(10, 2)
  net_amount_aud        Decimal @db.Decimal(10, 2)
  commission_amount_aud Decimal @db.Decimal(10, 2)

  stripe_transfer_id String?                @unique
  status             MilestoneReleaseStatus @default(PENDING)

  approved_by_user_id String?
  approved_at         DateTime?
  transferred_at      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([order_id, milestone_sequence])
  @@index([order_id])
}

model StripeWebhookEvent {
  id               String   @id @default(cuid())
  stripe_event_id  String   @unique
  event_type       String
  processed        Boolean  @default(false)
  processing_error String?
  raw_payload      Json
  received_at      DateTime @default(now())
  processed_at     DateTime?

  @@index([stripe_event_id])
  @@index([event_type])
  @@index([processed])
}

// ─────────────────────────────────────────────
// M10 — CREDENTIAL VAULT MODELS
// ─────────────────────────────────────────────

model OrderAccessCredential {
  id       String @id @default(cuid())

  order_id String
  order    Order  @relation(fields: [order_id], references: [id])

  // Who stored this credential
  stored_by_user_id String
  stored_by_user    User   @relation("CredentialStorer", fields: [stored_by_user_id], references: [id])

  label                   String         // e.g. "Server SSH Key", "Admin Password"
  credential_type         CredentialType
  keyvault_secret_name    String         // Azure Key Vault secret name
  keyvault_secret_version String?        // KV version GUID, set after store

  is_active Boolean @default(true)

  // Access tracking
  access_count        Int       @default(0)
  last_accessed_at    DateTime?
  last_accessed_by_id String?
  last_accessed_ip    String?

  // Rotation tracking
  rotated_at    DateTime?
  rotation_note String?

  // Soft delete / purge
  deleted_at         DateTime?
  deleted_by_user_id String?
  purged_at          DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  access_logs CredentialAccessLog[]

  @@index([order_id])
  @@index([stored_by_user_id])
  @@index([credential_type])
  @@index([is_active])
}

model CredentialAccessLog {
  id            String                @id @default(cuid())

  credential_id String
  credential    OrderAccessCredential @relation(fields: [credential_id], references: [id])

  order_id          String
  event_type        String    // STORED, RETRIEVED, DELETED, PURGED
  actor_user_id     String?   // null for system/job actions
  actor_ip          String?
  actor_user_agent  String?
  secret_version_read String?
  purge_result      String?
  note              String?

  created_at DateTime @default(now())

  @@index([credential_id])
  @@index([order_id])
  @@index([actor_user_id])
  @@index([event_type])
}

// ─────────────────────────────────────────────
// M12 — ADMIN PANEL & COMPLIANCE
// ─────────────────────────────────────────────

model AmlCheck {
  id                  String    @id @default(cuid())

  // Who was screened
  user_id             String
  user                User      @relation("AmlSubject", fields: [user_id], references: [id])

  // Who triggered the screen
  triggered_by_id     String
  triggered_by        User      @relation("AmlTrigger", fields: [triggered_by_id], references: [id])

  // Screening inputs (snapshot at screen time)
  full_name_screened  String
  dob_screened        DateTime?
  country_screened    String?

  // Provider response
  // MVP: stubbed with manual flag capability
  // Phase 6: wire to Comply Advantage or ComplyLaunch API
  provider            String    @default("MANUAL")
  provider_reference  String?   // external screening ID
  raw_response        Json?     // full provider JSON response

  // Results
  pep_match           Boolean   @default(false)
  sanctions_match     Boolean   @default(false)
  adverse_media_match Boolean   @default(false)
  overall_result      String    // CLEAR | FLAGGED | PENDING_REVIEW

  // Admin review after screening
  reviewed_by_id      String?
  reviewed_by         User?     @relation("AmlReviewer", fields: [reviewed_by_id], references: [id])
  review_notes        String?
  reviewed_at         DateTime?
  final_determination String?   // CLEARED | SUSPENDED | ESCALATED

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([user_id])
  @@index([overall_result])
  @@index([pep_match])
  @@index([sanctions_match])
}

model PlatformConfig {
  key           String   @id  // e.g. 'maintenance_mode', 'min_price_aud'
  value         Json     // stored as JSON — can be string, number, bool, object
  description   String?  // human-readable explanation of this config
  updated_by_id String?
  updated_at    DateTime @updatedAt
  created_at    DateTime @default(now())
}
