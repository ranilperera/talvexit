# Copy to .env.local

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onys_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_min_32_chars

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_KEY_VAULT_URL=

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App
PORT=3001
NODE_ENV=development
