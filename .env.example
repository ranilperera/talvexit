# Copy to .env.local

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onys_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_min_32_chars

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Where Stripe billing portal sends users when they click "Return to site"
STRIPE_PORTAL_RETURN_URL=

# Subscription / invoicing — issuer details for PDF tax invoices
COMPANY_NAME=Onsys Pty Ltd
COMPANY_ABN=
COMPANY_GST_REGISTERED=true
COMPANY_ADDRESS=Australia
INVOICE_PREFIX=INV

# Azure Blob — separate container for subscription invoice PDFs (optional;
# falls back to AZURE_STORAGE_CONTAINER if unset)
AZURE_BLOB_INVOICES_CONTAINER=invoices

# Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_KEY_VAULT_URL=

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Email (SMTP — legacy; transport is now Microsoft Graph in workers/.env)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where to send notifications of new public /contact form submissions.
# Falls back to EMAIL_FROM, then 'admin@wavefuldigital.com.au' if unset.
CONTACT_ADMIN_EMAIL=admin@wavefuldigital.com.au

# App
PORT=3001
NODE_ENV=development

# Frontend (NEXT_PUBLIC_* are inlined at build time and visible to the browser)
# Override the brand contact emails surfaced in the UI without a code change.
# Defaults live in apps/web/src/lib/brand.ts.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_LEGAL_EMAIL=
NEXT_PUBLIC_COMPLIANCE_EMAIL=
