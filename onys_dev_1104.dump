cmnsv3gj5000bi4tvdhzjjtq8	cmnsv1fzw0008i4tvoek2grzb	cmnogbz5500040ctvk0h77tjv	DIRECT	Firewall Outbound Internet Traffic Rule Configuration	FIREWALL	{"price": 450, "title": "Firewall Outbound Internet Traffic Rule Configuration", "domain": "FIREWALL", "currency": "AUD", "in_scope": ["Review of existing firewall ruleset and outbound traffic policy", "Definition of rule parameters including source zone, destination zone, port, protocol, and action", "Creation and insertion of the outbound internet traffic rule in the correct policy order", "Verification that the rule functions as intended using live traffic or connection testing", "Review for rule conflicts or unintended policy bypass introduced by the new rule", "Documentation of the new rule including purpose, owner, and date of implementation"], "hours_max": 3, "hours_min": 1, "objective": "Configure and implement a specific outbound internet traffic firewall rule to control, permit, or restrict egress traffic from the internal network to the internet, ensuring the rule is correctly defined, tested, and documented in accordance with the organisation's security policy.", "assumptions": ["Customer has administrative access to the firewall management interface", "The firewall make, model, and current software version are supported and functional", "The customer can clearly define the source, destination, port, and protocol requirements for the rule", "A maintenance window is available to apply and test the change with minimal business disruption"], "deliverables": ["Implemented and verified outbound firewall rule applied to the production firewall", "Post-implementation test results confirming rule behaves as specified", "Configuration change record documenting rule details, rationale, and implementation date"], "out_of_scope": ["Changes to inbound or NAT firewall rules", "Firewall firmware or software upgrades", "Full firewall policy audit or security hardening", "Network topology redesign or re-addressing", "Configuration of proxy, content filtering, or web gateway services", "Ongoing firewall management or monitoring after rule implementation"], "prerequisites": ["Administrative credentials or authorised access for the assigned engineer to the firewall", "Written confirmation of the rule requirements including source IP or subnet, destination, port, and protocol", "Change approval or change management authorisation from the customer if required by internal policy"], "milestone_count": 1}	\N	1	3	2026-04-10 22:21:06.248	OPEN	1	1	\N	2026-04-10 12:08:06.257	2026-04-10 12:11:08.522	\N
cmnsw0bg50003p0tvt7l697ai	cmnsvycbl0000p0tvpuya1nsv	cmnogbz5500040ctvk0h77tjv	DIRECT	SQL Server 2019 Installation with Backup Configuration on Azure Windows Server	DATABASE	{"price": 1200, "title": "SQL Server 2019 Installation with Backup Configuration on Azure Windows Server", "domain": "DATABASE", "currency": "AUD", "in_scope": ["Provision and configure an appropriately sized Azure Windows Server VM suitable for SQL Server 2019 workloads", "Install and configure Microsoft SQL Server 2019 with appropriate edition and feature selection based on customer requirements", "Configure SQL Server instance settings including memory allocation, tempdb optimisation, and authentication mode", "Apply SQL Server security hardening including sa account management, surface area configuration, and Windows Firewall rules", "Configure automated SQL Server backup jobs using SQL Server Agent covering full, differential, and transaction log backups", "Set up Azure Blob Storage as the backup destination for offsite retention of database backup files", "Validate the installation and backup solution via test backup and restore operation with documented results"], "hours_max": 12, "hours_min": 6, "objective": "Deploy a fully configured Microsoft SQL Server 2019 instance on an Azure-hosted Windows Server virtual machine, including instance configuration, security hardening, and an automated backup solution to ensure data protection and recoverability in a production-grade Azure environment.", "assumptions": ["Customer holds an active Azure subscription with sufficient quota and permissions to provision virtual machines and storage accounts", "Customer has a valid SQL Server 2019 licence or is eligible for Azure Hybrid Benefit; licensing cost is not included in this engagement", "The Azure VM size and storage tier will be selected to meet the customer's stated workload requirements prior to provisioning", "Remote access to the Azure VM via RDP or Azure Bastion will be available to the engineer throughout the engagement", "Customer accepts that backup retention policy and schedule will be defined and agreed upon before implementation begins"], "deliverables": ["Fully installed and configured SQL Server 2019 instance running on an Azure Windows Server VM", "Automated backup jobs configured in SQL Server Agent with full, differential, and transaction log schedules targeting Azure Blob Storage", "Post-installation configuration document detailing instance settings, service accounts, firewall rules, and backup policy", "Evidence of a successful test backup and restore operation confirming backup integrity and recoverability"], "out_of_scope": ["Database schema design, creation of application databases, or data migration from existing systems", "SQL Server licensing procurement — customer must supply a valid SQL Server 2019 licence or Azure Hybrid Benefit entitlement", "Azure networking design including VNet, NSG, or ExpressRoute configuration beyond VM-level firewall rules", "High availability or disaster recovery configuration such as Always On Availability Groups or Log Shipping", "Application integration, ODBC/DSN configuration, or connection string setup for third-party applications", "Ongoing SQL Server administration, monitoring, or managed DBA services post-deployment"], "prerequisites": ["Active Azure subscription with Owner or Contributor role access provided to the engineer", "SQL Server 2019 installation media or product key made available prior to engagement start", "Written confirmation of backup retention requirements, schedule frequency, and target Azure Storage Account or permission to create one", "Agreed VM sizing and Azure region selection documented before provisioning commences"], "milestone_count": 1}	\N	1	1	2026-04-10 12:41:00	AWARDED	1	1	cmnsw5kno0006p0tvd7p8d30q	2026-04-10 12:33:39.317	2026-04-10 12:56:13.113	2026-04-10 12:56:13.076
